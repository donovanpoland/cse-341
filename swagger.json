{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "CSE 341 Contacts API",
    "description": "REST API for CURD management of contacts."
  },
  "host": "contacts-api-g59t.onrender.com",
  "basePath": "/",
  "tags": [
    {
      "name": "Contacts",
      "description": "Create, read, update, and delete contact records"
    }
  ],
  "schemes": [
    "https"
  ],
  "securityDefinitions": {},
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/contacts/": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "description": "Get all Contacts with GET method",
        "responses": {
          "200": {
            "description": "Contacts retrieved successfully"
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "post": {
        "tags": [
          "Contacts"
        ],
        "description": "Create new Contact with POST method",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Json containing firstName, lastName, email, favoriteColor, birthday obtained via res.body",
            "schema": {
              "type": "object",
              "properties": {
                "firstName": {
                  "example": "CreateFirstName"
                },
                "lastName": {
                  "example": "CreateLastName"
                },
                "email": {
                  "example": "email@example.com"
                },
                "favoriteColor": {
                  "example": "blue"
                },
                "birthday": {
                  "example": "2024-12-28"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact created successfully"
          },
          "400": {
            "description": "Request validation failed"
          },
          "409": {
            "description": "Conflict"
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "description": "Get contact by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "req.params of ID representing the Contact to be updated"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact retrieved successfully"
          },
          "400": {
            "description": "Invalid contact id format"
          },
          "404": {
            "description": "Contact not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "put": {
        "tags": [
          "Contacts"
        ],
        "description": "Update Contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "req.params of an ID representing the Contact to be updated"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "firstName": {
                  "example": "updateFirstName"
                },
                "lastName": {
                  "example": "UpdateLastName"
                },
                "email": {
                  "example": "email@example.com"
                },
                "favoriteColor": {
                  "example": "red"
                },
                "birthday": {
                  "example": "2025-01-01"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact updated successfully"
          },
          "400": {
            "description": "Request validation failed"
          },
          "404": {
            "description": "Contact not found"
          },
          "409": {
            "description": "Conflict"
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "delete": {
        "tags": [
          "Contacts"
        ],
        "description": "Delete contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "req.params of an ID representing the Contact to be updated"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact deleted successfully"
          },
          "400": {
            "description": "Invalid contact id format"
          },
          "404": {
            "description": "Contact not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "definitions": {
    "Contact": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "example": "Jane"
        },
        "lastName": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "example": "jane@example.com"
        },
        "favoriteColor": {
          "type": "string",
          "example": "Blue"
        },
        "birthday": {
          "type": "string",
          "example": "1998-04-20"
        }
      }
    }
  }
}