<!DOCTYPE html>
<html lang="en">
	<%- include('./partials/head') %>
	<body>
		<%- include('./partials/header') %>

		<main class="grid">
			<h1><%= title %></h1>
			<section class="flex_colum card">
				<h2>Contacts API</h2>
				<p>Test contacts API calls</p>
				<ul>
					<li>
						<a
							href="/contacts"
							target="_blank"
							rel="noopener noreferrer"
							>View All Contacts JSON</a
						>
					</li>
				</ul>
				<h3>Contact list (limit 10)</h3>
				<ol>
					<% contacts.forEach(contact => { %>
					<li>
						<a
							href="/contact/<%=contact._id %>"
							target="_blank"
							rel="noopener noreferrer"
							><%= contact.firstName %>
							<%= contact.lastName %>
						</a>
					</li>
					<% }); %>
				</ol>
			</section>
		</main>

		<%- include('./partials/footer') %>
	</body>
</html>
